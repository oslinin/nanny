# Copy to .env and fill in what you need. uv does NOT auto-load .env; load it
# with `uv run --env-file .env main.py` (or `set -a; . ./.env; set +a` first).
# Everything below is optional: with no working Gemini backend at all,
# ClassifierAgent/ResponderAgent/InsightsAgent fall back to offline
# heuristics/templates, so the app stays fully runnable either way.

# -- Model access (local / AI Studio) ----------------------------------------
GEMINI_API_KEY=
# Alternative to GEMINI_API_KEY; either satisfies _has_api_key().
# GOOGLE_API_KEY=
# NANNY_GEMINI_MODEL=gemini-flash-latest

# -- Server -------------------------------------------------------------------
# NANNY_PORT=8000
# NANNY_LOG_LEVEL=INFO
# Require an X-Nanny-Token header on POST /api/quick-tap, /api/chat, etc.
# NANNY_API_TOKEN=
# Comma-separated origins allowed to call the API cross-origin (e.g. a
# GitHub Pages frontend on a different domain than this server).
# NANNY_ALLOWED_ORIGINS=

# -- Deploy (scripts/deploy.sh) ----------------------------------------------
# scripts/deploy.sh reads all of this. It deploys the agent to Vertex AI Agent
# Runtime, the dashboard to Cloud Run, and points the GitHub Pages frontend at
# the result — writing NANNY_AGENT_ENGINE_RESOURCE_NAME and NANNY_SERVICE_URL
# back here as it goes. Preview it with `scripts/deploy.sh` (dry run, no creds
# needed); deploy with `scripts/deploy.sh --execute`.
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-east1
# GCS bucket for the agent deploy's staging artifacts (required for step 1).
# GOOGLE_CLOUD_STAGING_BUCKET=
# Cloud Run service name (default: nanny).
# NANNY_CLOUD_RUN_SERVICE=nanny
# Set by the deploy script; also set GOOGLE_GENAI_USE_VERTEXAI=true to reach
# Gemini through Vertex with the service account (no API key).
# GOOGLE_GENAI_USE_VERTEXAI=true
# NANNY_AGENT_ENGINE_RESOURCE_NAME=
# NANNY_SERVICE_URL=

# -- Evidence-based insights: opt-in research tools --------------------------
# Google Search (ADK's built-in grounding tool) lights up automatically
# whenever a real model backend is configured above (GEMINI_API_KEY or
# Vertex) — no separate key of its own. The Corpus tab toggles it per parent.

# -- Parent-uploaded reference corpus (opt-in, off by default) ---------------
# NANNY_RAG_ENABLED=
# Vertex AI RAG's region — independent of GOOGLE_CLOUD_LOCATION above, which
# is often "global" for google_search grounding. RAG isn't available in
# "global", so it always needs its own real region.
# NANNY_RAG_LOCATION=us-east1

# -- Server-side speech-to-text fallback (opt-in, off by default) -----------
# The mic button uses the browser's Web Speech API unless this is enabled.
# NANNY_STT_ENABLED=
