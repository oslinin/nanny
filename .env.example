# Copy to .env and fill in what you need. uv does NOT auto-load .env; load it
# with `uv run --env-file .env main.py` (or `set -a; . ./.env; set +a` first).
# Everything below is optional: with no working Gemini backend at all,
# ClassifierAgent/ResponderAgent/InsightsAgent fall back to offline
# heuristics/templates, so the app stays fully runnable either way.

# -- Model access (local / AI Studio) ----------------------------------------
GEMINI_API_KEY=
# Alternative to GEMINI_API_KEY; either satisfies _has_api_key().
# GOOGLE_API_KEY=
# NANNY_GEMINI_MODEL=gemini-flash-latest

# -- Server -------------------------------------------------------------------
# NANNY_PORT=8000
# NANNY_LOG_LEVEL=INFO
# Require an X-Nanny-Token header on POST /api/quick-tap, /api/chat, etc.
# NANNY_API_TOKEN=
# Comma-separated origins allowed to call the API cross-origin (e.g. a
# GitHub Pages frontend on a different domain than this server).
# NANNY_ALLOWED_ORIGINS=

# -- Vertex AI Agent Runtime (opt-in; deploy target instead of local) --------
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-east1
# Required only by `uv run python -m nanny.agent_engine_app` (deploy script).
# GOOGLE_CLOUD_STAGING_BUCKET=
# Set on the dashboard/bridge once a graph is deployed, to call it instead of
# running the workflow in-process.
# NANNY_AGENT_ENGINE_RESOURCE_NAME=

# -- Evidence-based insights: opt-in research tools --------------------------
# Consensus.app via MCP, for scientific-literature-grounded answers.
# NANNY_CONSENSUS_MCP_URL=
# NANNY_CONSENSUS_API_KEY=
# Google Programmable Search Engine, for general web grounding.
# GOOGLE_CSE_ID=
# GOOGLE_CSE_API_KEY=

# -- Parent-uploaded reference corpus (opt-in, off by default) ---------------
# NANNY_RAG_ENABLED=

# -- Server-side speech-to-text fallback (opt-in, off by default) -----------
# The mic button uses the browser's Web Speech API unless this is enabled.
# NANNY_STT_ENABLED=
